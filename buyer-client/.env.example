# Path to the encrypted keystore JSON file (wallet shared with the agent)
KEYSTORE_PATH=../stockanalyst/.studio/wallets/0x1FF095E1C5Cf4bC72a3DC54be17B6cf85043Fb67.json

# Wallet password (same as WALLET_PASSWORD in stockanalyst/.studio/.env.local)
WALLET_PASSWORD=your_wallet_password_here

# Agent A2A endpoint (must be running: bag dev or bag run)
AGENT_ENDPOINT=http://localhost:9000

# Provider wallet address (the agent/seller)
PROVIDER_ADDRESS=0x1FF095E1C5Cf4bC72a3DC54be17B6cf85043Fb67

# UOMP Memory Guard — portfolio context store (must be running locally)
# Start with: uomp-guard start  (or npx tsx apps/guard/src/index.ts)
UOMP_GUARD_URL=http://127.0.0.1:9374
UOMP_GUARD_TOKEN=your_guard_jwt_token_here
