# ── Wallet ────────────────────────────────────────────────────────────────────
# Path to the buyer's encrypted keystore JSON
KEYSTORE_PATH=../stockanalyst/.studio/wallets/0x1FF095E1C5Cf4bC72a3DC54be17B6cf85043Fb67.json

# Keystore decryption password (same as WALLET_PASSWORD in stockanalyst/.studio/.env.local)
WALLET_PASSWORD=your_wallet_password_here

# ── ERC-8183 flow  (npm run dev) ──────────────────────────────────────────────
# Cloud seller A2A endpoint — from `bag deploy` output (bnbagent-api.bnbchain.world/…/a2a)
AGENT_ENDPOINT=https://bnbagent-api.bnbchain.world/v1/rt/<runtime-id>/a2a

# OAuth2 Cognito credentials — from `bag deploy provision-cognito`
# Leave blank for local agent (no auth required)
AGENT_CLIENT_ID=
AGENT_CLIENT_SECRET=

# Seller wallet address (shown in stockanalyst/app/agent/studio.toml [wallet].address)
PROVIDER_ADDRESS=0x1FF095E1C5Cf4bC72a3DC54be17B6cf85043Fb67

# ── x402 flow  (npm run x402) ─────────────────────────────────────────────────
# Base URL for the x402 channel. Two modes:
#   Local:    http://localhost:9000           (x402 + A2A share one port — bag dev / python main.py)
#   Deployed: shown by `bag deploy info` as x402_url (a separate public port, no Cognito)
#             e.g. https://bnbagent-api.bnbchain.world/v1/rt/<id>/x402
# Default is localhost:9000; only set this to override.
# X402_ENDPOINT=http://localhost:9000

# U token EIP-712 domain — only set if the U token contract uses different values.
# Verify via: cast call <U_TOKEN> "name()" --rpc-url $BSC_TESTNET_RPC
# U_TOKEN_DOMAIN_NAME=U
# U_TOKEN_DOMAIN_VERSION=1

# ── UOMP Memory Guard ─────────────────────────────────────────────────────────
# Portfolio context store — must be running locally before either flow starts.
# Seed with: node guard-mock.mjs  (from agent-demo root)
UOMP_GUARD_URL=http://127.0.0.1:9374
UOMP_GUARD_TOKEN=your_guard_jwt_token_here
